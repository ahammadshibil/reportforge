# ----- Server -----
PORT=5000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string

# ----- Auth (single-tenant whitelabel admin) -----
# Either ADMIN_PASSWORD (plain) for local dev, OR ADMIN_PASSWORD_HASH (bcrypt) for prod.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
# ADMIN_PASSWORD_HASH=$2a$10$...
# AUTH_DISABLED=1   # dev only — bypass auth entirely

# ----- Whitelabel brand -----
BRAND_NAME=ReportForge
BRAND_TAGLINE=Autonomous reporting
BRAND_COLOR=#0f766e
BRAND_LOGO_URL=
BRAND_LOGO_TEXT=RF
BRAND_DOMAIN=reports.example.com
BRAND_FOOTER=Generated by ReportForge. Reply to opt out.
BRAND_SUPPORT_EMAIL=
BRAND_THEME=auto

# ----- LLM synthesis (Phase 3) -----
# When set, replaces the offline extractive synthesizer with Claude.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ----- Connectors (Phase 2) -----
# Google Drive OAuth — get from https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/connections/google/callback

# Notion OAuth — get from https://www.notion.so/my-integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:5000/api/connections/notion/callback

# Airtable — uses per-connection PAT, no global config needed.

# ----- Email delivery (Phase 4) -----
# Pick one. Resend preferred; SMTP works as fallback.
RESEND_API_KEY=
EMAIL_FROM="ReportForge <reports@example.com>"

# SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=0
