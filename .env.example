# ----- Server -----
PORT=5000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string

# ----- Auth (single-tenant whitelabel admin) -----
# Either ADMIN_PASSWORD (plain) for local dev, OR ADMIN_PASSWORD_HASH (bcrypt) for prod.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
# ADMIN_PASSWORD_HASH=$2a$10$...
# AUTH_DISABLED=1   # dev only — bypass auth entirely

# ----- Whitelabel brand -----
BRAND_NAME=BYOR
BRAND_TAGLINE=Build Your Own Report
BRAND_COLOR=#0f766e
BRAND_LOGO_URL=
BRAND_LOGO_TEXT=BY
BRAND_DOMAIN=reports.example.com
BRAND_FOOTER=Generated by BYOR. Reply to opt out.
BRAND_SUPPORT_EMAIL=
BRAND_THEME=auto

# ----- LLM synthesis (text) -----
# Bring your own model. Provider is auto-detected from whichever key you set,
# or set LLM_PROVIDER explicitly.
#
# Option A: per-provider shortcuts (any one is enough)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
GEMINI_API_KEY=
#
# Option B: generic — any OpenAI-compatible endpoint
# LLM_PROVIDER=anthropic | openai | gemini   (omit for auto-detect from keys)
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
#
# Examples:
#   Perplexity   LLM_PROVIDER=openai  LLM_BASE_URL=https://api.perplexity.ai  LLM_MODEL=sonar
#   Groq         LLM_PROVIDER=openai  LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.3-70b-versatile
#   OpenRouter   LLM_PROVIDER=openai  LLM_BASE_URL=https://openrouter.ai/api/v1   LLM_MODEL=deepseek/deepseek-chat
#   Together     LLM_PROVIDER=openai  LLM_BASE_URL=https://api.together.xyz/v1    LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ----- LLM vision (template extraction) -----
# Optional override for the image→schema call. Lets you run a cheap
# text-only provider (Perplexity, Groq) for synthesis AND a separate
# vision-capable key for templates. If unset, falls back to the text LLM.
# Recommended pairing with Perplexity: Gemini Flash free tier.
VISION_LLM_PROVIDER=
VISION_LLM_API_KEY=
VISION_LLM_MODEL=
VISION_LLM_BASE_URL=

# ----- Connectors (Phase 2) -----
# Google Drive OAuth — get from https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/connections/google/callback

# Notion OAuth — get from https://www.notion.so/my-integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:5000/api/connections/notion/callback

# Airtable — uses per-connection PAT, no global config needed.

# ----- Email delivery (Phase 4) -----
# Pick one. Resend preferred; SMTP works as fallback.
RESEND_API_KEY=
EMAIL_FROM="BYOR <reports@example.com>"

# SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=0
